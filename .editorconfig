# EditorConfig – https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.php]
indent_size = 4

[*.twig]
indent_size = 4

[*.{yml,yaml}]
indent_size = 4

[*.json]
indent_size = 4

[*.xml]
indent_size = 4

[*.js]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
