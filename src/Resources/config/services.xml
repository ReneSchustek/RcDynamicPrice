<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
           http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <service id="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelper">
            <argument type="service" id="product.repository"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelperInterface"
                 alias="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelper"/>

        <service id="Ruhrcoder\RcDynamicPrice\Service\CategoryChainLoader">
            <argument type="service" id="category.repository"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Service\CategoryChainLoaderInterface"
                 alias="Ruhrcoder\RcDynamicPrice\Service\CategoryChainLoader"/>

        <service id="Ruhrcoder\RcDynamicPrice\Service\MeterConfigResolver">
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\CategoryChainLoaderInterface"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Service\MeterConfigResolverInterface"
                 alias="Ruhrcoder\RcDynamicPrice\Service\MeterConfigResolver"/>

        <service id="Ruhrcoder\RcDynamicPrice\Service\LengthSplitter"/>

        <service id="Ruhrcoder\RcDynamicPrice\Service\LengthSplitterInterface"
                 alias="Ruhrcoder\RcDynamicPrice\Service\LengthSplitter"/>

        <service id="Ruhrcoder\RcDynamicPrice\Service\CartItemSplitAssembler">
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\LengthSplitterInterface"/>
            <argument type="service" id="monolog.logger.rc_dynamic_price"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Service\CartItemSplitAssemblerInterface"
                 alias="Ruhrcoder\RcDynamicPrice\Service\CartItemSplitAssembler"/>

        <service id="Ruhrcoder\RcDynamicPrice\Storefront\Subscriber\ProductPageSubscriber">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\MeterConfigResolverInterface"/>
            <argument type="service" id="request_stack"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Storefront\Subscriber\StorefrontResponseSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Subscriber\LineItemSubscriber">
            <argument type="service" id="request_stack"/>
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelperInterface"/>
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\MeterConfigResolverInterface"/>
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\CartItemSplitAssemblerInterface"/>
            <argument type="service" id="monolog.logger.rc_dynamic_price"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Subscriber\CacheInvalidationSubscriber">
            <argument type="service" id="Shopware\Core\Framework\Adapter\Cache\CacheInvalidator"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Cart\DynamicPriceProcessor">
            <argument type="service" id="Shopware\Core\Checkout\Cart\Price\QuantityPriceCalculator"/>
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelperInterface"/>
            <argument type="service" id="monolog.logger.rc_dynamic_price"/>
            <!-- Laeuft nach ProductCartProcessor (Prioritaet 5000) -->
            <tag name="shopware.cart.processor" priority="4800"/>
        </service>

    </services>
</container>
