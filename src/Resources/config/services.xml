<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
           http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <service id="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelper">
            <argument type="service" id="product.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Storefront\Subscriber\ProductPageSubscriber">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelper"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Subscriber\LineItemSubscriber">
            <argument type="service" id="request_stack"/>
            <argument type="service" id="Ruhrcoder\RcDynamicPrice\Service\MeterProductHelper"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Ruhrcoder\RcDynamicPrice\Cart\DynamicPriceProcessor">
            <argument type="service" id="Shopware\Core\Checkout\Cart\Price\QuantityPriceCalculator"/>
            <!-- Läuft nach ProductCartProcessor (Priorität 5000) -->
            <tag name="shopware.cart.processor" priority="4800"/>
        </service>

    </services>
</container>
