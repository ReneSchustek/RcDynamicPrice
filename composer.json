{
    "name": "ruhrcoder/rc-dynamic-price",
    "description": "Shopware plugin for length-based price calculation",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Ruhrcoder",
            "homepage": "https://ruhrcoder.de"
        }
    ],
    "require": {
        "php": ">=8.2",
        "shopware/core": "~6.7.0 || ~6.8.0",
        "shopware/storefront": "~6.7.0 || ~6.8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Ruhrcoder\\RcDynamicPrice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ruhrcoder\\RcDynamicPrice\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "quality": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "extra": {
        "shopware-plugin-class": "Ruhrcoder\\RcDynamicPrice\\RcDynamicPrice",
        "label": {
            "de-DE": "Dynamischer Meterpreis",
            "en-GB": "Dynamic Meter Price"
        },
        "description": {
            "de-DE": "Längenbasierte Preisberechnung: Kunden geben ihre Wunschlänge in mm ein, der Preis wird live berechnet und in den Warenkorb übernommen.",
            "en-GB": "Length-based price calculation: customers enter their desired length in mm, the price is calculated live and transferred to the cart."
        }
    }
}
